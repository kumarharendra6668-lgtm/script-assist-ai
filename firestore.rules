rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'signupDate', 'plan']) &&
             data.keys().size() == 3 &&
             data.email is string &&
             data.email.size() <= 200 &&
             data.signupDate == request.time &&
             data.plan is string &&
             data.plan.size() <= 20;
    }

    function isValidDraft(data) {
      return data.keys().hasAll(['topic', 'platform', 'tone', 'language', 'script', 'createdAt']) &&
             data.topic is string && data.topic.size() <= 500 &&
             data.platform is string && data.platform.size() <= 50 &&
             data.tone is string && data.tone.size() <= 50 &&
             data.language is string && data.language.size() <= 50 &&
             data.script is string && data.script.size() <= 10000 &&
             data.createdAt == request.time &&
             (!data.keys().contains('hooks') || data.hooks is list);
    }

    // Since we only create and update trial/plan
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow create only if they are setting their own document
      allow create: if isSignedIn() && request.auth.uid == userId &&
                    isValidId(userId) &&
                    isValidUser(incoming()) &&
                    // Enforce that email matches auth token (Google OAuth or email provider)
                    incoming().email == request.auth.token.email &&
                    incoming().plan == 'Trial';
      allow update: if isSignedIn() && request.auth.uid == userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['plan']);

      match /drafts/{draftId} {
        allow list, get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId &&
                      isValidId(draftId) &&
                      isValidDraft(incoming());
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
